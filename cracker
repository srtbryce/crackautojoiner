local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local friendUser = "TheirUsernameHere"  -- Replace with friend's username
local apiUrl = "https://your-ngrok-url.example.com/getjob?user=" .. friendUser

local lastFriendJobId = ""
local lastTeleportTime = 0
local debounceTime = 3  -- Minimum seconds between teleports
local pollInterval = 0.1  -- Poll every 0.1 seconds

print("Auto-follower started for " .. friendUser .. "! Polling every " .. pollInterval .. "s")

spawn(function()
    while true do
        local success, response = pcall(function()
            return HttpService:GetAsync(apiUrl)
        end)

        if success then
            local data = HttpService:JSONDecode(response)
            local friendJobId = data.jobId
            local friendPlaceId = data.placeId

            if friendJobId and friendJobId ~= "" and friendJobId ~= lastFriendJobId then
                lastFriendJobId = friendJobId
                local myPlaceId = game.PlaceId
                if friendPlaceId == myPlaceId then
                    local myJobId = game.JobId
                    local now = tick()
                    if myJobId ~= friendJobId and (now - lastTeleportTime) >= debounceTime then
                        print("Friend changed to new job ID: " .. friendJobId .. " → Teleporting!")
                        lastTeleportTime = tick()
                        local teleportSuccess, errorMsg = pcall(function()
                            TeleportService:TeleportToPlaceInstance(friendPlaceId, friendJobId, {Players.LocalPlayer})
                        end)
                        if not teleportSuccess then
                            warn("Teleport failed: " .. tostring(errorMsg))
                        end
                    end
                end
            end
        else
            warn("Poll failed: " .. tostring(response))
        end

        task.wait(pollInterval)
    end
end)
