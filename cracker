local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

-- The "user" key you used in your API. Could be "friend" or anything consistent.
local apiUserKey = "friend"  
local apiUrl = "https://crackaj.vercel.app/getjob?user=" .. apiUserKey

local lastJobId = ""
local lastTeleportTime = 0
local debounceTime = 3      -- Min seconds between teleports
local pollInterval = 0.1    -- How often to check

spawn(function()
    while true do
        local success, response = pcall(function()
            return HttpService:GetAsync(apiUrl)
        end)

        if success then
            local data = HttpService:JSONDecode(response)
            local friendJobId = data.jobId
            local friendPlaceId = data.placeId

            if friendJobId and friendJobId ~= "" and friendJobId ~= lastJobId then
                lastJobId = friendJobId
                local myPlaceId = game.PlaceId
                if friendPlaceId == myPlaceId then
                    local now = tick()
                    if game.JobId ~= friendJobId and (now - lastTeleportTime) >= debounceTime then
                        lastTeleportTime = now
                        local ok, err = pcall(function()
                            TeleportService:TeleportToPlaceInstance(friendPlaceId, friendJobId, {Players.LocalPlayer})
                        end)
                        if not ok then
                            warn("Teleport failed: " .. tostring(err))
                        else
                            print("Teleported to new jobId: " .. friendJobId)
                        end
                    end
                else
                    warn("Friend is in a different place: " .. friendPlaceId)
                end
            end
        else
            warn("Failed to fetch jobId: " .. tostring(response))
        end

        task.wait(pollInterval)
    end
end)
