local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local jobId = game.JobId
if jobId == "" then
    warn("Not in a live server (e.g., Studio test mode). Can't get job ID.")
    return
end

local myUser = "global"
local apiUrl = "https://8f352b3f-b533-4a33-b6f4-312ef0eace4d-00-107ppso2ogc0.janeway.replit.dev/update" -- FIXED

local data = {
    user = myUser,
    jobId = jobId,
    placeId = game.PlaceId
}

local success, response = pcall(function()
    return HttpService:PostAsync(
        apiUrl,
        HttpService:JSONEncode(data),
        Enum.HttpContentType.ApplicationJson
    )
end)

if success then
    print("Job ID sent to API: " .. jobId)
else
    warn("Failed to send: " .. response)
end
