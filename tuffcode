local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")

local Packages = ReplicatedStorage:WaitForChild("Packages")
local Datas = ReplicatedStorage:WaitForChild("Datas")
local Shared = ReplicatedStorage:WaitForChild("Shared")

local Synchronizer = require(Packages:WaitForChild("Synchronizer"))
local AnimalsData = require(Datas:WaitForChild("Animals"))
local AnimalsShared = require(Shared:WaitForChild("Animals"))

local WS_URL = "wss://websocket-test-dp06.onrender.com"

RunService:Set3dRenderingEnabled(false)

local function getBestBrainrotInServer()
	local plots = Workspace:FindFirstChild("Plots")
	if not plots then
		return nil, nil
	end

	local best = nil
	local bestValue = -math.huge
	local bestPlot = nil

	for _, plot in ipairs(plots:GetChildren()) do
		local success, container = pcall(function()
			return Synchronizer:Get(plot.Name)
		end)

		if success and container then
			local animalList = container:Get("AnimalList")

			if type(animalList) == "table" then
				for slot, animalData in pairs(animalList) do
					if type(animalData) == "table" then
						local animalName = animalData.Index
						local info = AnimalsData[animalName]

						if info then
							local genSuccess, generation = pcall(function()
								return AnimalsShared:GetGeneration(
									animalName,
									animalData.Mutation,
									animalData.Traits,
									nil
								)
							end)

							if genSuccess and generation then
								local rarity = info.Rarity or "Unknown"
								local isValidRarity = (rarity == "Secret" or rarity == "OG")
								local isFastEnough = generation >= 35000000

								if isValidRarity and isFastEnough then
									if generation > bestValue then
										bestValue = generation
										bestPlot = plot.Name

										best = {
											name = info.DisplayName or animalName,
											gen = generation,
											mutation = animalData.Mutation or "None",
											slot = slot,
											jobId = game.JobId,
											rarity = rarity
										}
									end
								end
							end
						end
					end
				end
			end
		end
	end

	return best, bestPlot
end

local socket = nil

local function connectSocket()
	local success, ws = pcall(function()
		return WebSocket.connect(WS_URL)
	end)

	if success and ws then
		socket = ws

		ws.OnClose:Connect(function()
			socket = nil
			task.wait(2)
			connectSocket()
		end)
	else
		task.wait(2)
		connectSocket()
	end
end

connectSocket()

local function sendToServer(data)
	if not data or not socket then return end

	local payload = {
		type = "log",
		name = data.name,
		gen = data.gen,
		mutation = data.mutation,
		rarity = data.rarity,
		jobId = data.jobId,
		time = os.time()
	}

	pcall(function()
		socket:Send(HttpService:JSONEncode(payload))
	end)
end

local lastSentId = nil

RunService.Heartbeat:Connect(function()
	local best = getBestBrainrotInServer()

	if best then
		local id = best.name .. "_" .. best.gen .. "_" .. best.jobId

		if id ~= lastSentId then
			lastSentId = id
			sendToServer(best)
		end
	end
end)
